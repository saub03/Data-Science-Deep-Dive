     ]
    }
   ],
   "source": [
    "s1 = set([1,2,3]) \n",
    "s2 = set([3,4,5]) \n",
    "\n",
    "#교집합\n",
    "print(s1&s2)\n",
    "#합집합\n",
    "print(s1|s2)\n",
    "#차집합\n",
    "print(s1-s2)"
   ]
  },
