   "source": [
    "파이썬 객체 중 list, dict, set는 자동으로 shallow copy가 되버림;; 그래서 똑같은거 2개 만들려면 copy 라이브러리 임포트 해서 copy 매서드를 사용해주어야 함"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "3248f3b2",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[1, 2, 3] [2, 3]\n"
     ]
    }
   ],
   "source": [
    "from copy import copy\n",
    "\n",
    "a = [1, 2, 3]\n",
    "b = a # b is a -> true    shallow copy\n",
    "b = copy(a) # deep copy\n",
    "\n",
    "del b[0]\n",
    "print(a, b)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "380885ad",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "4 3\n"
     ]
    }
   ],
   "source": [
    "a, b = (3, 4)\n",
    "a, b = b, a\n",
    "print(a,b)"
   ]
  }
